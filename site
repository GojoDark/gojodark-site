<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Gojo Dark</title>

<style>
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
    font-family: Arial, sans-serif;
    color: white;
    overflow-x: hidden;

    /* FUNDO COM IMAGEM + OVERLAY */
    background:
        linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.9)),
        url('https://images.unsplash.com/photo-1520975922324-8b456906c813') center/cover no-repeat fixed;
}

/* overlay vermelho leve */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at center, rgba(255,0,0,0.15), transparent 60%);
    z-index: -1;
}

/* HEADER */
header {
    position: fixed;
    width: 100%;
    padding: 15px 40px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: space-between;
    z-index: 1000;
}

nav a {
    color: #aaa;
    margin-left: 20px;
    text-decoration: none;
}

nav a.active {
    color: #ff2a2a;
    border-bottom: 2px solid #ff2a2a;
}

/* HERO COM IMAGEM */
.hero {
    height: 100vh;
    background:
        linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.9)),
        url('https://i.pinimg.com/1200x/27/ca/3a/27ca3a9e0c9645216fafd6826ef7dcbd.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
}

.hero h1 {
    font-size: 64px;
    text-shadow: 0 0 18px rgba(255,0,0,0.7);
}

/* SECTIONS */
.section {
    padding: 100px 40px;
    text-align: center;
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
}

/* CARD (clicável) */
.card {
    display: block;
    text-decoration: none;
    color: white;
    cursor: pointer;
    position: relative;
    z-index: 10;

    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    overflow: hidden;
    transition: 0.3s;
    border: 1px solid rgba(255,0,0,0.2);
}

.card:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow: 0 0 20px rgba(255,0,0,0.6);
}

.card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

.card h3 {
    padding: 14px;
}

/* BOTÕES */
.btn {
    display: inline-block;
    margin: 10px;
    padding: 10px 18px;
    border: 1px solid #ff2a2a;
    color: white;
    text-decoration: none;
    border-radius: 6px;
}

.btn:hover {
    background: #ff2a2a;
    color: black;
}

/* FADE */
.fade {
    opacity: 0;
    transform: translateY(20px);
    transition: 0.6s;
}

.fade.show {
    opacity: 1;
    transform: translateY(0);
}
</style>
</head>

<body>

<header>
    <div>GojoDark</div>
    <nav>
        <a href="#home">Home</a>
        <a href="#projetos">Projetos</a>
        <a href="#links">Links</a>
        <a href="#sobre">Sobre</a>
        <a href="#contato">Contato</a>
    </nav>
</header>

<!-- HOME -->
<section id="home" class="hero fade">
    <h1>Gojo Dark</h1>
</section>

<!-- PROJETOS -->
<section id="projetos" class="section fade">
    <h2>Projetos</h2>
    <div class="grid">
        <div class="card">
            <img src="https://i.pinimg.com/736x/c4/c3/5c/c4c35c183627d7369ea6c86ca04c9447.jpg">
            <h3>Jogo em Andamento</h3>
        </div>
        <div class="card">
            <img src="https://i.pinimg.com/1200x/43/bb/0b/43bb0b561b277b6ae768da3214124461.jpg">
            <h3>APP??</h3>
        </div>
    </div>
</section>

<!-- LINKS -->
<section id="links" class="section fade">
    <h2>Links</h2>

    <div class="grid">

        <a href="https://www.youtube.com/@GojoDark1hz" target="_blank" rel="noopener noreferrer" class="card">
            <img src="https://i.pinimg.com/736x/91/ce/c2/91cec23f8553dbb9d9b4a1a3ad294cfc.jpg">
            <h3>YouTube</h3>
        </a>

        <a href="https://discord.gg/vh5PhPACQT" target="_blank" rel="noopener noreferrer" class="card">
            <img src="https://i.pinimg.com/1200x/fc/ea/9d/fcea9d73a542f8a88907ba603ebdc379.jpg">
            <h3>Discord</h3>
        </a>

        <a href="https://steamcommunity.com/id/GojoDark/" target="_blank" rel="noopener noreferrer" class="card">
            <img src="https://i.pinimg.com/1200x/f7/29/e0/f729e0889564d4fca9fd39b2f8903862.jpg">
            <h3>Steam</h3>
        </a>

    </div>
</section>

<!-- SOBRE -->
<section id="sobre" class="section fade">
    <h2>Sobre</h2>
    <p>
        Criador de conteúdo e projetos digitais.<br>
        Foco em jogos, estética dark e experiências visuais simples.
    </p>
</section>

<!-- CONTATO -->
<section id="contato" class="section fade">
    <h2>Contato</h2>
    <a href="https://discord.gg/vh5PhPACQT" target="_blank" rel="noopener noreferrer" class="btn">Discord</a>
    <a href="https://steamcommunity.com/id/GojoDark/" target="_blank" rel="noopener noreferrer" class="btn">Steam</a>
</section>

<script>
// BOTÃO ATIVO
const links = document.querySelectorAll("nav a");
const sections = document.querySelectorAll("section");

window.addEventListener("scroll", () => {
    let current = "";
    sections.forEach(sec => {
        const top = window.scrollY;
        const offset = sec.offsetTop - 120;
        const height = sec.offsetHeight;
        if (top >= offset && top < offset + height) current = sec.id;
    });

    links.forEach(link => {
        link.classList.remove("active");
        if (link.getAttribute("href") === "#" + current) {
            link.classList.add("active");
        }
    });
});

// FADE
const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
        if(entry.isIntersecting){
            entry.target.classList.add("show");
        }
    });
});
document.querySelectorAll(".fade").forEach(el => observer.observe(el));
</script>

</body>
</html>
